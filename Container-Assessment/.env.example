# --- Network Ports ---
# APP_PORT is used by docker-compose to map the host port to the container
APP_PORT=8080
# PORT is the internal port the Go application listens on
PORT=8080
# MONGO_PORT is the port used for the MongoDB service
MONGO_PORT=27017

# --- Database Configuration ---
# Admin credentials for the MongoDB container
MONGO_INITDB_ROOT_USERNAME=change-me
MONGO_INITDB_ROOT_PASSWORD=change-me
# The specific database name the app will use
DB_NAME=much_todo_db
# Full connection string for the backend to connect to MongoDB
MONGO_URI=mongodb://change-me:change-me@mongodb:27017/much_todo_db?authSource=admin

# --- Authentication ---
# Secret key for signing JWT tokens (keep this long and secure)
JWT_SECRET_KEY=replace-with-a-long-random-secret
# How long the user session stays active
JWT_EXPIRATION_HOURS=72

# --- App Settings & Observability ---
# Set to true if using Redis for caching
ENABLE_CACHE=false
# Logging verbosity (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
# Log output style (json is best for Kubernetes/Cloud-Native)
LOG_FORMAT=json
